{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Multi-FX Editor",
  "version": "0.1.0",
  "identifier": "com.multi-fx.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Multi-FX Editor",
        "width": 1180,
        "height": 820,
        "minWidth": 940,
        "minHeight": 680
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
